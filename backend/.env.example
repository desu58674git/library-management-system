# ============================================
# LIBRARY MANAGEMENT SYSTEM - ENVIRONMENT VARS
# ============================================

# Server
NODE_ENV=development
PORT=5000

# Database (Supabase / Neon / Local PostgreSQL)
DATABASE_URL=postgresql://username:password@host:5432/library_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=library_db
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_SSL=false

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key
JWT_REFRESH_EXPIRES_IN=30d

# CORS
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Fine per day (in currency units)
FINE_PER_DAY=0.50
